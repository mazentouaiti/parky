GtkWidget*
create_delete_warning (void)
{
  GtkWidget *delete_warning;
  GtkWidget *dialog_vbox1;
  GtkWidget *fixed13;
  GtkWidget *label57;
  GtkWidget *image13;
  GtkWidget *dialog_action_area1;
  GtkWidget *helpbutton1;
  GtkWidget *cancelbutton1;
  GtkWidget *okbutton1;

  delete_warning = gtk_dialog_new ();
  gtk_window_set_title (GTK_WINDOW (delete_warning), _("Warning"));
  gtk_window_set_type_hint (GTK_WINDOW (delete_warning), GDK_WINDOW_TYPE_HINT_DIALOG);
  gtk_dialog_set_has_separator (GTK_DIALOG (delete_warning), FALSE);

  dialog_vbox1 = GTK_DIALOG (delete_warning)->vbox;
  gtk_widget_show (dialog_vbox1);

  fixed13 = gtk_fixed_new ();
  gtk_widget_show (fixed13);
  gtk_box_pack_start (GTK_BOX (dialog_vbox1), fixed13, TRUE, TRUE, 0);

  label57 = gtk_label_new (_("ARE YOU SURE ?"));
  gtk_widget_show (label57);
  gtk_fixed_put (GTK_FIXED (fixed13), label57, 88, 120);
  gtk_widget_set_size_request (label57, 128, 32);

  image13 = gtk_image_new_from_stock ("gtk-dialog-warning", GTK_ICON_SIZE_DIALOG);
  gtk_widget_show (image13);
  gtk_fixed_put (GTK_FIXED (fixed13), image13, 120, 48);
  gtk_widget_set_size_request (image13, 72, 56);

  dialog_action_area1 = GTK_DIALOG (delete_warning)->action_area;
  gtk_widget_show (dialog_action_area1);
  gtk_button_box_set_layout (GTK_BUTTON_BOX (dialog_action_area1), GTK_BUTTONBOX_END);

  helpbutton1 = gtk_button_new_from_stock ("gtk-help");
  gtk_widget_show (helpbutton1);
  gtk_dialog_add_action_widget (GTK_DIALOG (delete_warning), helpbutton1, GTK_RESPONSE_HELP);
  GTK_WIDGET_SET_FLAGS (helpbutton1, GTK_CAN_DEFAULT);

  cancelbutton1 = gtk_button_new_from_stock ("gtk-cancel");
  gtk_widget_show (cancelbutton1);
  gtk_dialog_add_action_widget (GTK_DIALOG (delete_warning), cancelbutton1, GTK_RESPONSE_CANCEL);
  GTK_WIDGET_SET_FLAGS (cancelbutton1, GTK_CAN_DEFAULT);

  okbutton1 = gtk_button_new_from_stock ("gtk-delete");
  gtk_widget_show (okbutton1);
  gtk_dialog_add_action_widget (GTK_DIALOG (delete_warning), okbutton1, GTK_RESPONSE_OK);
  GTK_WIDGET_SET_FLAGS (okbutton1, GTK_CAN_DEFAULT);

  g_signal_connect ((gpointer) helpbutton1, "clicked",
                    G_CALLBACK (on_helpbutton1_clicked),
                    NULL);
  g_signal_connect ((gpointer) cancelbutton1, "clicked",
                    G_CALLBACK (on_cancelbutton1_clicked),
                    NULL);
  g_signal_connect ((gpointer) okbutton1, "clicked",
                    G_CALLBACK (on_okbutton1_clicked),
                    NULL);

  /* Store pointers to all widgets, for use by lookup_widget(). */
  GLADE_HOOKUP_OBJECT_NO_REF (delete_warning, delete_warning, "delete_warning");
  GLADE_HOOKUP_OBJECT_NO_REF (delete_warning, dialog_vbox1, "dialog_vbox1");
  GLADE_HOOKUP_OBJECT (delete_warning, fixed13, "fixed13");
  GLADE_HOOKUP_OBJECT (delete_warning, label57, "label57");
  GLADE_HOOKUP_OBJECT (delete_warning, image13, "image13");
  GLADE_HOOKUP_OBJECT_NO_REF (delete_warning, dialog_action_area1, "dialog_action_area1");
  GLADE_HOOKUP_OBJECT (delete_warning, helpbutton1, "helpbutton1");
  GLADE_HOOKUP_OBJECT (delete_warning, cancelbutton1, "cancelbutton1");
  GLADE_HOOKUP_OBJECT (delete_warning, okbutton1, "okbutton1");

  return delete_warning;
}

GtkWidget*
create_logout (void)
{
  GtkWidget *logout;
  GtkWidget *dialog_vbox2;
  GtkWidget *fixed14;
  GtkWidget *image14;
  GtkWidget *label58;
  GtkWidget *dialog_action_area2;
  GtkWidget *cancelbutton2;
  GtkWidget *okbutton2;

  logout = gtk_dialog_new ();
  gtk_window_set_title (GTK_WINDOW (logout), _("Log out"));
  gtk_window_set_type_hint (GTK_WINDOW (logout), GDK_WINDOW_TYPE_HINT_DIALOG);
  gtk_dialog_set_has_separator (GTK_DIALOG (logout), FALSE);

  dialog_vbox2 = GTK_DIALOG (logout)->vbox;
  gtk_widget_show (dialog_vbox2);

  fixed14 = gtk_fixed_new ();
  gtk_widget_show (fixed14);
  gtk_box_pack_start (GTK_BOX (dialog_vbox2), fixed14, TRUE, TRUE, 0);

  image14 = gtk_image_new_from_stock ("gtk-quit", GTK_ICON_SIZE_DIALOG);
  gtk_widget_show (image14);
  gtk_fixed_put (GTK_FIXED (fixed14), image14, 112, 16);
  gtk_widget_set_size_request (image14, 80, 64);

  label58 = gtk_label_new (_("ARE YOU SURE?"));
  gtk_widget_show (label58);
  gtk_fixed_put (GTK_FIXED (fixed14), label58, 88, 104);
  gtk_widget_set_size_request (label58, 128, 24);

  dialog_action_area2 = GTK_DIALOG (logout)->action_area;
  gtk_widget_show (dialog_action_area2);
  gtk_button_box_set_layout (GTK_BUTTON_BOX (dialog_action_area2), GTK_BUTTONBOX_END);

  cancelbutton2 = gtk_button_new_from_stock ("gtk-cancel");
  gtk_widget_show (cancelbutton2);
  gtk_dialog_add_action_widget (GTK_DIALOG (logout), cancelbutton2, GTK_RESPONSE_CANCEL);
  GTK_WIDGET_SET_FLAGS (cancelbutton2, GTK_CAN_DEFAULT);

  okbutton2 = gtk_button_new_from_stock ("gtk-quit");
  gtk_widget_show (okbutton2);
  gtk_dialog_add_action_widget (GTK_DIALOG (logout), okbutton2, GTK_RESPONSE_OK);
  GTK_WIDGET_SET_FLAGS (okbutton2, GTK_CAN_DEFAULT);

  g_signal_connect ((gpointer) cancelbutton2, "clicked",
                    G_CALLBACK (on_cancelbutton2_clicked),
                    NULL);
  g_signal_connect ((gpointer) okbutton2, "clicked",
                    G_CALLBACK (on_okbutton2_clicked),
                    NULL);

  /* Store pointers to all widgets, for use by lookup_widget(). */
  GLADE_HOOKUP_OBJECT_NO_REF (logout, logout, "logout");
  GLADE_HOOKUP_OBJECT_NO_REF (logout, dialog_vbox2, "dialog_vbox2");
  GLADE_HOOKUP_OBJECT (logout, fixed14, "fixed14");
  GLADE_HOOKUP_OBJECT (logout, image14, "image14");
  GLADE_HOOKUP_OBJECT (logout, label58, "label58");
  GLADE_HOOKUP_OBJECT_NO_REF (logout, dialog_action_area2, "dialog_action_area2");
  GLADE_HOOKUP_OBJECT (logout, cancelbutton2, "cancelbutton2");
  GLADE_HOOKUP_OBJECT (logout, okbutton2, "okbutton2");

  return logout;
}

